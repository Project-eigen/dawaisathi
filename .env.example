# ──────────────────────────────────────────────────────────────
# 1) Google Gemini — medicine photo reading (required for scanning)
# Free key (no card): https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional model override. Default: gemini-2.5-flash (free tier, good OCR).
# GEMINI_MODEL=gemini-2.5-flash

# ──────────────────────────────────────────────────────────────
# 2) Clerk — patient / family-member login (optional; app runs without it)
# Create an app at https://dashboard.clerk.com and copy both keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# These point Clerk at the in-app pages (defaults shown).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ──────────────────────────────────────────────────────────────
# 3) Neon Postgres — shared reminders so family can see a patient's meds
# Create a free DB at https://neon.tech (or add Neon from the Vercel
# Marketplace, which sets DATABASE_URL automatically).
DATABASE_URL=

# ──────────────────────────────────────────────────────────────
# 4) Web Push + cron reminders (optional) — fire dose alerts even when the
# app/tab is closed. Needs Clerk + Neon above. Generate the key pair once:
#   npm run gen-vapid
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact URI sent to push services (your email or site URL).
VAPID_SUBJECT=mailto:you@example.com
# Shared secret the scheduler must send to call /api/cron/reminders.
# Use a long random string. cron-job.org sends it as:
#   Authorization: Bearer <CRON_SECRET>   (or ?secret=<CRON_SECRET>)
CRON_SECRET=
